<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <MapGeneratorDef>
    <defName>DeepRimVertical_Underground</defName>
    <label>deep underground</label>
    <isUnderground>true</isUnderground>
    <disableCallAid>true</disableCallAid>
    <ignoreAreaRevealedLetter>true</ignoreAreaRevealedLetter>
    <pocketMapProperties>
      <biome>DeepRimVertical_UndergroundBiome</biome>
      <temperature>0</temperature>
    </pocketMapProperties>
    <genSteps>
      <li>DeepRimVertical_UndergroundLayout</li>
      <li>DeepRimVertical_UndergroundMaterialize</li>
      <li>DeepRimVertical_UndergroundFog</li>
    </genSteps>
  </MapGeneratorDef>

  <MapGeneratorDef>
    <defName>DeepRimVertical_UpperFloor</defName>
    <label>upper floor</label>
    <ignoreAreaRevealedLetter>true</ignoreAreaRevealedLetter>
    <disableCallAid>true</disableCallAid>
    <defaultUnderGridTerrain>DeepRimVertical_UpperVoid</defaultUnderGridTerrain>
    <pocketMapProperties>
      <biome>DeepRimVertical_UpperFloorBiome</biome>
      <temperature>20</temperature>
    </pocketMapProperties>
    <genSteps>
      <li>DeepRimVertical_UpperFloorInit</li>
    </genSteps>
  </MapGeneratorDef>

  <GenStepDef>
    <defName>DeepRimVertical_UndergroundLayout</defName>
    <order>100</order>
    <genStep Class="DeepRim.Vertical.VerticalMaps.GenStep_DeepRimVerticalUndergroundLayout" />
  </GenStepDef>

  <GenStepDef>
    <defName>DeepRimVertical_UndergroundMaterialize</defName>
    <order>200</order>
    <genStep Class="DeepRim.Vertical.VerticalMaps.GenStep_DeepRimVerticalUndergroundMaterialize" />
  </GenStepDef>

  <GenStepDef>
    <defName>DeepRimVertical_UndergroundFog</defName>
    <order>1500</order>
    <genStep Class="DeepRim.Vertical.VerticalMaps.GenStep_DeepRimVerticalUndergroundFog" />
  </GenStepDef>

  <GenStepDef>
    <defName>DeepRimVertical_UpperFloorInit</defName>
    <order>100</order>
    <genStep Class="DeepRim.Vertical.VerticalMaps.GenStep_DeepRimVerticalUpperFloorInit" />
  </GenStepDef>
</Defs>
